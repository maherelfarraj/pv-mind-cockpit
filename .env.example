# PV_Mind Cockpit — official domain and branding
# Copy to .env for local overrides. Production values use pvmind.ai.

# Web (Next.js) — included for cross-platform deployment alignment
NEXT_PUBLIC_APP_NAME="PV_Mind Cockpit"
NEXT_PUBLIC_PARENT_BRAND="GridMind EPC"
NEXT_PUBLIC_PUBLIC_URL="https://pvmind.ai"
NEXT_PUBLIC_APP_URL="https://app.pvmind.ai"
NEXT_PUBLIC_API_URL="https://api.pvmind.ai"
NEXT_PUBLIC_SUPPORT_EMAIL="support@pvmind.ai"
NEXT_PUBLIC_NO_REPLY_EMAIL="no-reply@pvmind.ai"
NEXT_PUBLIC_REPORT_BRAND_NAME="PV_Mind Cockpit by GridMind EPC"

# Mobile and desktop (Expo)
EXPO_PUBLIC_APP_NAME="PV_Mind Cockpit"
EXPO_PUBLIC_PARENT_BRAND="GridMind EPC"
EXPO_PUBLIC_PUBLIC_URL="https://pvmind.ai"
EXPO_PUBLIC_APP_URL="https://app.pvmind.ai"
EXPO_PUBLIC_API_URL="https://api.pvmind.ai"
EXPO_PUBLIC_SUPPORT_EMAIL="support@pvmind.ai"
EXPO_PUBLIC_NO_REPLY_EMAIL="no-reply@pvmind.ai"
EXPO_PUBLIC_REPORT_BRAND_NAME="PV_Mind Cockpit by GridMind EPC"
