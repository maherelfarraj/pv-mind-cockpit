{
  "name": "@pvmind/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for PV Mind Cockpit",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^5.0.10",
    "typescript": "^5.5.4"
  }
}
