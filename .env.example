# PV Mind Cockpit — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── Supabase ──────────────────────────────────────────────
# Get these from: https://app.supabase.com/project/<project-id>/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# ─── Application ───────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=production          # production | staging | development
EXPO_PUBLIC_APP_VERSION=0.1.0
EXPO_PUBLIC_DOMAIN=pvmind.ai
