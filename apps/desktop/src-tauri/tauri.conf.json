{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PV Mind Cockpit",
  "version": "0.1.0",
  "identifier": "com.gridmind.pvmindcockpit",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter web dev",
    "beforeBuildCommand": "pnpm --filter web build"
  },
  "app": {
    "windows": [
      {
        "title": "PV Mind Cockpit",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": []
  }
}
